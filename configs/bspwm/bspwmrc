#!/bin/sh
# peak-linux — bspwm Configuration
# macOS-inspired tiling window manager for X11

# ── Autostart ─────────────────────────────────────────────────
pgrep -x sxhkd > /dev/null || sxhkd &
pgrep -x picom > /dev/null || picom --config "$HOME/.config/picom/picom.conf" &
pgrep -x dunst > /dev/null || dunst &

# Polybar
"$HOME/.config/polybar/launch.sh" &

# Plank dock
pgrep -x plank > /dev/null || plank &

# Wallpaper
feh --bg-fill "$HOME/.local/share/wallpapers/default.jpg" 2>/dev/null || \
    feh --bg-fill /usr/share/backgrounds/archlinux/simple.png 2>/dev/null || \
    xsetroot -solid "#1C1C1E"

# Polkit agent
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &

# Clipboard manager
pgrep -x clipmenud > /dev/null || clipmenud &

# Network applet
pgrep -x nm-applet > /dev/null || nm-applet &

# Bluetooth applet
pgrep -x blueman-applet > /dev/null || blueman-applet &

# Cursor theme
xsetroot -cursor_name left_ptr
xrdb -merge <<< "Xcursor.theme: WhiteSur-cursors"
xrdb -merge <<< "Xcursor.size: 24"

# ── Desktops ──────────────────────────────────────────────────
bspc monitor -d 1 2 3 4 5 6 7 8 9

# ── Appearance ────────────────────────────────────────────────
# Gaps (macOS-like spacing)
bspc config window_gap          8
bspc config top_padding         40
bspc config bottom_padding      8
bspc config left_padding        8
bspc config right_padding       8

# Borders
bspc config border_width            2
bspc config focused_border_color    "#007AFF"
bspc config normal_border_color     "#3A3A3C"
bspc config presel_feedback_color   "#5856D6"

# ── Behavior ──────────────────────────────────────────────────
bspc config split_ratio             0.52
bspc config borderless_monocle      true
bspc config gapless_monocle         false
bspc config single_monocle          false
bspc config focus_follows_pointer   true
bspc config pointer_modifier        mod4
bspc config pointer_action1         move
bspc config pointer_action2         resize_side

# ── Window Rules ──────────────────────────────────────────────
bspc rule -a Plank manage=on border=off locked=on focus=off follow=off layer=above
bspc rule -a Thunar state=floating rectangle=900x600+0+0 center=true
bspc rule -a imv state=floating
bspc rule -a mpv state=floating
bspc rule -a "org.gnome.Calculator" state=floating
bspc rule -a pavucontrol state=floating
bspc rule -a nm-connection-editor state=floating
bspc rule -a blueman-manager state=floating
bspc rule -a Rofi state=floating
